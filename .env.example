# Django
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# ML inference service (auto-starts with Django when ML_AUTO_START=True)
ML_AUTO_START=True
ML_SERVICE_URL=http://127.0.0.1:8100
ML_SERVICE_TIMEOUT=60
# Relative to backend/ when unset; override with an absolute path if needed.
ML_ROOT_PATH=ml_service
ML_KNOWN_FACES_DIR=ml_service/known_faces
# Optional: Python with ML deps (fastapi, ultralytics, opencv). Defaults to backend venv or Django Python.
# ML_PYTHON=/var/www/TekEye_DIKHAN/Custom/backend/venv/bin/python
ML_API_PORT=8100
ML_API_HOST=127.0.0.1
ML_LIVE_STREAM_FPS=25
FRONTEND_ORIGIN=http://localhost:5173

# Background worker — saves ML detections while system runs (no browser needed)
DETECTION_WORKER_ENABLED=True
DETECTION_WORKER_AUTO_START=True
DETECTION_WORKER_INTERVAL_SEC=2
DETECTION_WORKER_CAMERA_REFRESH_SEC=60
