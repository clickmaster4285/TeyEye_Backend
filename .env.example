# Django
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# ML inference service (auto-starts with Django when ML_AUTO_START=True)
ML_AUTO_START=True
ML_SERVICE_URL=http://127.0.0.1:8100
ML_SERVICE_TIMEOUT=60
ML_ROOT_PATH=D:\ML\ML
# Optional: full path to Python with ML deps (fastapi, ultralytics, opencv). Defaults to Django Python.
# ML_PYTHON=C:\Python311\python.exe
ML_KNOWN_FACES_DIR=D:\ML\ML\known_faces
ML_API_PORT=8100
ML_LIVE_STREAM_FPS=25
FRONTEND_ORIGIN=http://localhost:5173
