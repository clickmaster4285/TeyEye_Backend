# Django
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# ML inference service (external ml_services/ on Server 2 — HTTP client only)
ML_SERVICE_URL=http://127.0.0.1:8100
ML_SERVICE_PUBLIC_URL=http://127.0.0.1:8100
ML_SERVICE_TIMEOUT=60
# Inference weights/GPU settings live in ml_services/.env
FRONTEND_ORIGIN=http://localhost:5173

# Background worker — saves ML detections while system runs (no browser needed)
DETECTION_WORKER_ENABLED=True
DETECTION_WORKER_AUTO_START=True
DETECTION_WORKER_INTERVAL_SEC=2
DETECTION_WORKER_CAMERA_REFRESH_SEC=60




ATTENDANCE_FACE_MIN_CONFIDENCE=0.25
ATTENDANCE_CAMERA_MARK_COOLDOWN_SECONDS=120
ATTENDANCE_MIN_CHECKOUT_HOURS=4
ATTENDANCE_MARK_ON_FACE_RECOGNITION_CAMERAS=True
ATTENDANCE_SNAPSHOT_ENABLED=True
ATTENDANCE_VIDEO_SECONDS=7
ATTENDANCE_VIDEO_FPS=15
ATTENDANCE_VIDEO_WIDTH=1280
ATTENDANCE_VIDEO_JPEG_QUALITY=95
ATTENDANCE_VIDEO_CRF=18